{# Round headline for OBS + audience phones.
   Mythbusters rounds (myths list set) show: label, debate title, myths, then the vote question.
   Other rounds show the single voting prompt only. #}
{% set round = round|default(null) %}
{% set poll = poll|default(null) %}
{% set myths = round ? round.myths|default([]) : [] %}
{% set voteAsk = poll ? poll.votingPrompt : (round ? round.question : '') %}

{% if myths|length > 0 %}
    <div class="round-prompt round-prompt--myths">
        {% if round.label and not hide_label|default(false) %}
            <div class="round-prompt-label">{{ round.label }}</div>
        {% endif %}
        {% if round.title %}
            <h1 class="round-prompt-title">{{ round.title }}</h1>
        {% endif %}
        <ul class="round-prompt-myths">
            {% for myth in myths %}
                <li>{{ myth }}</li>
            {% endfor %}
        </ul>
        {% if voteAsk %}
            <p class="round-prompt-ask">{{ voteAsk }}</p>
        {% endif %}
    </div>
{% else %}
    <h1 class="round-prompt-title round-prompt-title--solo">{{ voteAsk }}</h1>
{% endif %}
