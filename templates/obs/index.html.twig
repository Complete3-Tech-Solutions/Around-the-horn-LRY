{% extends 'base_obs.html.twig' %}

{% block title %}Around the Horn — OBS Display{% endblock %}
{% block body_class %}obs-bg-{{ bg|default('transparent') }} obs-theme-{{ dark|default(false) ? 'dark' : 'light' }}{% endblock %}

{% block body %}
<div id="obs-stage">
    <header class="obs-header">
        <div class="obs-brand">
            <img src="/img/logo.svg" alt="Innovate Alabama">
            <div>
                <div class="kicker">{{ event_config.subtitle }}</div>
                <div class="event">{{ event_config.title }}</div>
            </div>
        </div>
        <div class="obs-header-qr" id="obs-header-qr">
            {% if qr %}
                <div class="obs-qr"><img src="{{ qr }}" alt="Scan to vote"></div>
            {% endif %}
            <div class="obs-scan-label">Scan QR to <b>vote</b></div>
        </div>
    </header>

    <div id="obs-stage-inner"
         hx-get="{{ path('app_obs_results', {'bg': bg, 'screen': screen}) }}"
         hx-trigger="load, every 2s"
         hx-swap="innerHTML">
    </div>
</div>

{# Scale-to-fit: the stage is designed at a fixed 1920×1080 and uniformly
   scaled to the actual browser-source / LED-wall size (contain — never
   cropped, never stretched). Recomputes on every resize so any canvas works:
   set the OBS browser source to your wall's native resolution and it fills. #}
<script>
    (function () {
        var stage = document.getElementById('obs-stage');
        if (!stage) return;
        function fit() {
            var scale = Math.min(window.innerWidth / 1920, window.innerHeight / 1080);
            stage.style.transform = 'translate(-50%, -50%) scale(' + scale + ')';
        }
        window.addEventListener('resize', fit);
        window.addEventListener('orientationchange', fit);
        fit();
    })();
</script>
{% endblock %}
