{# Around the Horn — OBS stage fragment (body + header QR OOB) #}

<div id="obs-header-qr" class="obs-header-qr" hx-swap-oob="true">
    {% if qr %}
        <div class="obs-qr"><img src="{{ qr }}" alt="Scan to vote"></div>
    {% endif %}
    <div class="obs-scan-label">Scan QR to <b>vote</b></div>
</div>

{% if screen == 'winner' %}
    <div class="obs-winner-center">
        <div class="obs-crown">★ Audience Champion ★</div>
        {% if champion %}
            <div class="obs-av"><img src="{{ champion.founder.headshot }}" alt="{{ champion.founder.name }}"></div>
            <h1 class="obs-wname">{{ champion.founder.name }}</h1>
            <div class="obs-wsector">{{ champion.founder.sector }}</div>
            {% if champion.tie %}<div class="obs-wsector">Tie at the top — moderator's decision</div>{% endif %}
            <div class="obs-wcharity">Innovate Alabama directs the donation to <b>their desired charity</b></div>
        {% else %}
            <h1 class="obs-wname">—</h1>
            <div class="obs-wcharity">Tallying the final votes…</div>
        {% endif %}
    </div>

{% elseif screen == 'live' and activePoll %}
    <div class="obs-body">
        <div class="obs-round">
            <span class="pill">{{ round ? round.key : 'Live vote' }}</span>
        </div>
        <h1 class="obs-question">{{ activePoll.votingPrompt }}</h1>
        <div class="obs-rows">
            {% for row in liveResults %}
                {% set isLeader = row.isLeader and activePoll.totalVotes > 0 %}
                <div class="obs-row {{ isLeader ? 'lead' : '' }}">
                    <div class="obs-who">
                        <div class="obs-av"><img src="{{ row.founder.headshot }}" alt="{{ row.founder.name }}"></div>
                        <div>
                            <div class="nm">{{ row.founder.name }}</div>
                            <div class="rl">{{ row.founder.sector }}</div>
                        </div>
                    </div>
                    <div class="obs-meter">
                        <div class="obs-track">
                            <div class="obs-fill" style="width: {{ row.pct }}%;"></div>
                        </div>
                        <div class="obs-stat">
                            <div class="obs-pct">{{ row.pct }}%</div>
                            <div class="obs-vts">{{ row.count }} vote{{ row.count == 1 ? '' : 's' }}</div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>

{% elseif screen == 'standby' %}
    <div class="obs-body">
        <div class="obs-round">
            <span class="pill">Between rounds</span>
        </div>
        {% if lastRound and lastWinners is not empty %}
            <h1 class="obs-question">{{ lastRound.key }} goes to {{ lastWinners|map(f => f.name)|join(' & ') }}</h1>
        {% else %}
            <h1 class="obs-question">Scores are on the board</h1>
        {% endif %}
        <p class="obs-sub">
            {{ nextRound
                ? 'Up next — ' ~ nextRound.key
                : 'All rounds are in — champion reveal coming up.' }}
        </p>
        <div class="obs-standings">
            {% set topPoints = standings|length > 0 ? standings[0].points : 0 %}
            {% for row in standings %}
                {% set leads = row.points == topPoints and topPoints > 0 %}
                <div class="obs-stand-row {{ leads ? 'lead' : '' }}">
                    <div class="rank">{{ loop.index }}</div>
                    <div class="obs-av"><img src="{{ row.founder.headshot }}" alt="{{ row.founder.name }}"></div>
                    <div class="info">
                        <div class="nm">{{ row.founder.name }}</div>
                        <div class="rl">{{ row.founder.sector }}</div>
                    </div>
                    <div class="pts">
                        <div class="n">{{ row.points }}</div>
                        <div class="l">{{ row.points == 1 ? 'point' : 'points' }}</div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>

{% else %}
    {# Intro / pre-show #}
    <div class="obs-body intro-body">
        <div class="obs-eyebrow">
            <span class="pill">Panel</span>
        </div>
        <h1 class="obs-title">Around the <span class="cy">Horn</span></h1>
        <div class="obs-meet">Meet the Participants</div>
        <div class="obs-cards">
            {% for f in founders %}
                <div class="obs-card">
                    <div class="obs-av"><img src="{{ f.headshot }}" alt="{{ f.name }}"></div>
                    <div class="nm">{{ f.name }}</div>
                    <div class="rl">{{ f.sector }}</div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endif %}
