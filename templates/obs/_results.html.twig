{# Around the Horn — OBS stage fragment (body + footer + live-badge OOB) #}

{% set badgeClass = screen == 'intro' ? 'soon' : (screen == 'standby' ? 'standby' : '') %}
{% set badgeLabel = screen == 'intro' ? 'Starting Soon' : (screen == 'standby' ? 'Stand By' : (screen == 'winner' ? 'Final' : 'Live')) %}

<div id="obs-live-badge" class="obs-live-badge {{ badgeClass }}" hx-swap-oob="true">
    <span class="dot"></span>
    <span>{{ badgeLabel }}</span>
</div>

{# Horizontal scoreboard shown on the footer bottom line (every screen). #}
{% macro scoreline(standings) %}
    {% set topPoints = standings|length > 0 ? standings[0].points : 0 %}
    <div class="obs-scoreline">
        <span class="label">Scoreboard</span>
        {% for s in standings %}
            {% set lead = s.points == topPoints and topPoints > 0 %}
            <div class="obs-score-chip {{ lead ? 'lead' : '' }}">
                <div class="obs-chip-av">{% if s.founder.headshot %}<img src="{{ s.founder.headshot }}" alt="{{ s.founder.name }}">{% else %}{{ s.founder.initials }}{% endif %}</div>
                <div class="obs-chip-info"><span class="nm">{{ s.founder.name }}</span><span class="pts">{{ s.points }}</span></div>
            </div>
        {% endfor %}
    </div>
{% endmacro %}
{% import _self as ui %}

{% if screen == 'winner' %}
    <div class="obs-winner-center">
        <div class="obs-crown">★ Audience Champion ★</div>
        {% if champion %}
            <div class="obs-av"><img src="{{ champion.founder.headshot }}" alt="{{ champion.founder.name }}"></div>
            <h1 class="obs-wname">{{ champion.founder.name }}</h1>
            <div class="obs-wsector">{{ champion.founder.sector }}</div>
            {% if champion.tie %}<div class="obs-wsector">Tie at the top — moderator's decision</div>{% endif %}
            <div class="obs-wcharity">Innovate Alabama directs the donation to <b>{{ champion.founder.charity }}</b></div>
        {% else %}
            <h1 class="obs-wname">—</h1>
            <div class="obs-wcharity">Tallying the final votes…</div>
        {% endif %}
    </div>

    <footer class="obs-footer">
        <div class="obs-scan">
            <div>
                <div class="big">Thank you for <b>voting live</b></div>
                <div class="small">{{ eventTagline }}</div>
            </div>
        </div>
        <div class="obs-footer-right">
            {{ ui.scoreline(standings) }}
        </div>
    </footer>

{% elseif screen == 'live' and activePoll %}
    <div class="obs-body">
        <div class="obs-round">
            <span class="pill">{{ round ? round.key : 'Live vote' }}</span>
            {% if round %}<span class="topic">{{ round.label }}</span>{% endif %}
        </div>
        <h1 class="obs-question">{{ round ? round.question : activePoll.title }}</h1>
        <div class="obs-rows">
            {% for row in liveResults %}
                {% set isLeader = row.isLeader and activePoll.totalVotes > 0 %}
                <div class="obs-row {{ isLeader ? 'lead' : '' }}">
                    <div class="obs-who">
                        <div class="obs-av"><img src="{{ row.founder.headshot }}" alt="{{ row.founder.name }}"></div>
                        <div>
                            <div class="nm">{{ row.founder.name }}</div>
                            <div class="rl">{{ row.founder.sector }}</div>
                        </div>
                    </div>
                    <div class="obs-meter">
                        <div class="obs-track">
                            <div class="obs-fill" style="width: {{ row.pct }}%;"></div>
                        </div>
                        <div class="obs-stat">
                            <div class="obs-pct">{{ row.pct }}%</div>
                            <div class="obs-vts">{{ row.count }} vote{{ row.count == 1 ? '' : 's' }}</div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>

    <footer class="obs-footer">
        <div class="obs-scan">
            {% if qr %}
                <div class="obs-qr"><img src="{{ qr }}" alt="Scan to vote"></div>
            {% endif %}
            <div>
                <div class="big">Scan to <b>vote live</b></div>
                <div class="small">{{ activePoll.totalVotes|number_format }} votes cast · pick your favorite each round</div>
            </div>
        </div>
        <div class="obs-footer-right">
            {{ ui.scoreline(standings) }}
        </div>
    </footer>

{% elseif screen == 'standby' %}
    <div class="obs-body">
        <div class="obs-round">
            <span class="pill">Between rounds</span>
        </div>
        {% if lastRound and lastWinners is not empty %}
            <h1 class="obs-question">{{ lastRound.key }} goes to {{ lastWinners|map(f => f.name)|join(' & ') }}</h1>
        {% else %}
            <h1 class="obs-question">Scores are on the board</h1>
        {% endif %}
        <p class="obs-sub">
            {{ nextRound
                ? 'Up next — ' ~ nextRound.key ~ ': ' ~ nextRound.label
                : 'All rounds are in — champion reveal coming up.' }}
        </p>
        <div class="obs-standings">
            {% set topPoints = standings|length > 0 ? standings[0].points : 0 %}
            {% for row in standings %}
                {% set leads = row.points == topPoints and topPoints > 0 %}
                <div class="obs-stand-row {{ leads ? 'lead' : '' }}">
                    <div class="rank">{{ loop.index }}</div>
                    <div class="obs-av"><img src="{{ row.founder.headshot }}" alt="{{ row.founder.name }}"></div>
                    <div class="info">
                        <div class="nm">{{ row.founder.name }}</div>
                        <div class="rl">{{ row.founder.sector }}</div>
                    </div>
                    <div class="pts">
                        <div class="n">{{ row.points }}</div>
                        <div class="l">{{ row.points == 1 ? 'point' : 'points' }}</div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>

    <footer class="obs-footer">
        <div class="obs-scan">
            <div>
                <div class="big">Stand by for the <b>next round</b></div>
                <div class="small">Already scanned? Stay on your page — it follows the show.</div>
            </div>
        </div>
        <div class="obs-footer-right">
            {{ ui.scoreline(standings) }}
        </div>
    </footer>

{% else %}
    {# Intro / pre-show #}
    <div class="obs-body intro-body">
        <div class="obs-eyebrow">
            <span class="pill">Panel</span>
            <span class="sub">A founders roundtable</span>
        </div>
        <h1 class="obs-title">Around the <span class="cy">Horn</span></h1>
        <div class="obs-meet">Meet the Founders</div>
        <div class="obs-cards">
            {% for f in founders %}
                <div class="obs-card">
                    <div class="obs-av"><img src="{{ f.headshot }}" alt="{{ f.name }}"></div>
                    <div class="nm">{{ f.name }}</div>
                    <div class="rl">{{ f.sector }}</div>
                    <div class="obs-co"><span class="dot"></span>{{ f.charity }}</div>
                </div>
            {% endfor %}
        </div>
    </div>

    <footer class="obs-footer intro-footer">
        <div class="obs-scan">
            {% if qr %}
                <div class="obs-qr big"><img src="{{ qr }}" alt="Scan to vote"></div>
            {% endif %}
            <div>
                <div class="big">Scan to <b>join the vote</b></div>
                <div class="small">One scan covers every round — your phone follows the show.</div>
            </div>
        </div>
        <div class="obs-footer-right">
            {{ ui.scoreline(standings) }}
        </div>
    </footer>
{% endif %}
