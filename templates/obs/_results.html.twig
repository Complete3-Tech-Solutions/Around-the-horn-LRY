{# Around the Horn — OBS stage fragment (body + header QR OOB) #}

<div id="obs-header-qr" class="obs-header-qr" hx-swap-oob="true">
    {% if qr %}
        <div class="obs-qr"><img src="{{ qr }}" alt="Scan to vote"></div>
    {% endif %}
    <div class="obs-scan-label">Scan QR to <b>vote</b></div>
</div>

{% if screen == 'winner' %}
    <div class="obs-winner-center">
        <div class="obs-crown">★ Audience Champion ★</div>
        {% if champion %}
            <div class="obs-winner-tie{% if not champion.tie %} obs-winner-tie--solo{% endif %}">
                {% for f in champion.founders %}
                    <div class="obs-winner-person">
                        <div class="obs-av"><img src="{{ f.headshot }}" alt="{{ f.name }}"></div>
                        <h1 class="obs-wname">{{ f.name }}</h1>
                        <div class="obs-wsector">{{ f.sector }}</div>
                    </div>
                {% endfor %}
            </div>
            {% if champion.tie %}
                <div class="obs-wsector">Co-champions — {{ champion.points }} round{{ champion.points == 1 ? '' : 's' }} won each</div>
            {% else %}
                <div class="obs-wsector">{{ champion.points }} round{{ champion.points == 1 ? '' : 's' }} won</div>
            {% endif %}
        {% else %}
            <h1 class="obs-wname">—</h1>
            <div class="obs-wcharity">Tallying the final votes…</div>
        {% endif %}
    </div>

{% elseif screen == 'live' and activePoll %}
    {% set myths = round ? round.myths|default([]) : [] %}
    {% set hasMyths = myths|length > 0 %}
    {% set showMyths = hasMyths and not votingPhase|default(false) %}
    <div class="obs-body{% if showMyths %} obs-body--myths{% endif %}"{% if votingPhase|default(false) %} x-data="voteTimer('{{ activePoll.startAt|date('Y-m-d\\TH:i:s\\Z') }}', '{{ activePoll.endAt|date('Y-m-d\\TH:i:s\\Z') }}')"{% endif %}>
        <div class="obs-round">
            <span class="pill">{{ activePoll.roundLabel ?: round.key }}</span>
            {% if votingPhase|default(false) %}
                <div class="obs-vote-timer" :class="{ warn: isWarn, waiting: waiting, expired: isExpired }">
                    <span class="n" x-text="display">--:--</span>
                    <span class="l" x-text="label">left</span>
                </div>
            {% endif %}
        </div>
        {% if showMyths %}
            {% include 'components/_myth_round_header.html.twig' with {
                myths: myths,
                title: round.title,
                roundQuestion: activePoll.roundQuestion,
                votingPrompt: activePoll.votingPrompt,
                variant: 'obs',
            } %}
        {% else %}
            <h1 class="obs-question">{{ activePoll.votingPrompt }}</h1>
        {% endif %}
        {% if votingPhase|default(false) %}
        <div class="obs-rows">
            {% for row in liveResults %}
                {% set isLeader = row.isLeader and activePoll.totalVotes > 0 %}
                <div class="obs-row {{ isLeader ? 'lead' : '' }}">
                    <div class="obs-who">
                        <div class="obs-av"><img src="{{ row.founder.headshot }}" alt="{{ row.founder.name }}"></div>
                        <div>
                            <div class="nm">{{ row.founder.name }}</div>
                            <div class="rl">{{ row.founder.sector }}</div>
                        </div>
                    </div>
                    <div class="obs-meter">
                        <div class="obs-track">
                            <div class="obs-fill" style="width: {{ row.pct }}%;"></div>
                        </div>
                        <div class="obs-stat">
                            <div class="obs-pct">{{ row.pct }}%</div>
                            <div class="obs-vts">{{ row.count }} vote{{ row.count == 1 ? '' : 's' }}</div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
        {% elseif not showMyths %}
        <div class="obs-stage-lineup">
            {% for f in founders %}
                <div class="obs-stage-panel">
                    <div class="obs-av"><img src="{{ f.headshot }}" alt="{{ f.name }}"></div>
                    <div class="obs-stage-info">
                        <div class="nm">{{ f.name }}</div>
                        <div class="rl">{{ f.sector }}</div>
                    </div>
                </div>
            {% endfor %}
        </div>
        {% endif %}
    </div>

{% elseif screen == 'standby' %}
    <div class="obs-body">
        <div class="obs-round">
            <span class="pill">Between rounds</span>
        </div>
        {% if lastRound and lastWinners is not empty %}
            <h1 class="obs-question">{{ lastRound.key }} goes to {{ lastWinners|map(f => f.name)|join(' & ') }}</h1>
        {% else %}
            <h1 class="obs-question">Scores are on the board</h1>
        {% endif %}
        <p class="obs-sub">
            {{ nextRound
                ? 'Up next — ' ~ nextRound.key
                : 'All rounds are in — champion reveal coming up.' }}
        </p>
        <div class="obs-rows">
            {% for row in lastRoundResults|default([]) %}
                <div class="obs-row {{ row.isLeader and row.count > 0 ? 'lead' : '' }}">
                    <div class="obs-who">
                        <div class="obs-av"><img src="{{ row.founder.headshot }}" alt="{{ row.founder.name }}"></div>
                        <div>
                            <div class="nm">{{ row.founder.name }}</div>
                            <div class="rl">{{ row.founder.sector }}</div>
                        </div>
                    </div>
                    <div class="obs-meter">
                        <div class="obs-track">
                            <div class="obs-fill" style="width: {{ row.pct }}%;"></div>
                        </div>
                        <div class="obs-stat">
                            <div class="obs-pct">{{ row.pct }}%</div>
                            <div class="obs-vts">{{ row.count }} vote{{ row.count == 1 ? '' : 's' }}</div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>

{% else %}
    {# Intro / pre-show #}
    <div class="obs-body intro-body">
        <div class="obs-eyebrow">
            <span class="pill">Panel</span>
        </div>
        <h1 class="obs-title">Around the <span class="cy">Horn</span></h1>
        <div class="obs-meet">Meet the Participants</div>
        <div class="obs-cards">
            {% for f in founders %}
                <div class="obs-card">
                    <div class="obs-av"><img src="{{ f.headshot }}" alt="{{ f.name }}"></div>
                    <div class="nm">{{ f.name }}</div>
                    <div class="rl">{{ f.sector }}</div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endif %}
