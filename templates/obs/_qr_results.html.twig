<div class="qrx">
    <div class="qrx-card">
        <img class="qrx-logo" src="{{ event_state.theme == 'innovate-dark' ? '/img/logo.svg' : '/img/logo-ink.svg' }}" alt="Innovate Alabama">
        {% if qrCode %}
            <img class="qrx-img" src="{{ qrCode }}" alt="Scan to vote">
        {% endif %}
        <div class="qrx-label">Scan to <b>vote</b></div>
        {% if poll is defined and poll and poll.roundNumber %}
            <div class="qrx-code">Round {{ poll.roundNumber }}</div>
        {% elseif standby|default(false) %}
            <div class="qrx-code">Join now — voting opens with each round</div>
        {% endif %}
    </div>
</div>
