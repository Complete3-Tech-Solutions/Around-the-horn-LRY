{% extends 'base.html.twig' %}

{% block title %}Around the Horn — Innovate Alabama{% endblock %}

{% block body %}
<div class="min-h-screen bg-base-100 grid place-items-center px-4">
    <div class="max-w-lg w-full text-center">
        <img src="/img/logo.svg" alt="Innovate Alabama" class="h-24 w-24 mx-auto mb-4">
        <h1 class="text-4xl font-display mb-2" style="font-weight:200;">Around the Horn</h1>
        <p class="ia-text-gray uppercase tracking-[0.2em] text-xs mb-6">Innovate Alabama · Sloss Tech</p>
        <p class="mb-8 text-lg">Live audience voting for the founder debate. Scan the QR code shown on screen to vote in each round.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="{{ path('app_obs') }}" class="btn btn-neutral">Broadcast display (/obs)</a>
            <a href="{{ path('app_admin_index') }}" class="btn btn-outline">Moderator (/admin)</a>
        </div>
        <p class="mt-8 text-xs ia-text-gray">Private event tool · themed fork of OpenStreamPoll (MIT)</p>
    </div>
</div>
{% endblock %}
