{% extends 'base.html.twig' %}

{% block title %}Sign in — Around the Horn{% endblock %}

{% block body %}
<div class="min-h-screen bg-base-100 grid place-items-center px-4">
    <div class="w-full max-w-md">
        <div class="flex flex-col items-center mb-6">
            <img src="/img/logo.svg" alt="Innovate Alabama" class="h-16 w-16 mb-3">
            <h1 class="text-2xl font-display" style="font-weight:200;">Around the Horn — Admin</h1>
            <p class="text-xs ia-text-gray uppercase tracking-[0.18em] mt-1">Innovate Alabama · Sloss Tech</p>
        </div>

        <div class="card bg-base-100 border-2 border-base-300">
            <div class="card-body">
                <form method="post" class="space-y-4">
                    {% if error %}
                        <div class="alert alert-error text-sm">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                    {% endif %}

                    {% if app.user %}
                        <div class="alert alert-info text-sm">
                            Logged in as {{ app.user.userIdentifier }}, <a href="{{ path('app_logout') }}" class="link">Logout</a>
                        </div>
                    {% endif %}

                    <div class="form-control">
                        <label class="label" for="username"><span class="label-text">Username</span></label>
                        <input type="text" value="{{ last_username }}" name="_username" id="username" class="input input-bordered" autocomplete="username" required autofocus>
                    </div>

                    <div class="form-control">
                        <label class="label" for="password"><span class="label-text">Password</span></label>
                        <input type="password" name="_password" id="password" class="input input-bordered" autocomplete="current-password" required>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <label class="label cursor-pointer justify-start gap-2">
                        <input type="checkbox" name="_remember_me" class="checkbox checkbox-primary checkbox-sm">
                        <span class="label-text">Remember me</span>
                    </label>

                    <button class="btn btn-neutral w-full" type="submit">Sign in</button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
