{% extends 'base.html.twig' %}

{% block title %}Founders — Around the Horn{% endblock %}

{% block body %}
    {% include 'components/_brand_header.html.twig' with {'heading': 'Founders', 'subtitle': 'Moderator control'} %}

    <div class="min-h-screen">
        <div class="container mx-auto px-2 py-4 max-w-3xl">
            <div class="card bg-base-200 shadow-xl">
                <div class="card-body p-4">
                    <div class="flex flex-wrap items-center justify-between gap-2 mb-1">
                        <h2 class="text-lg font-bold">The ballot roster</h2>
                        <div class="flex gap-2">
                            <a href="{{ path('app_admin_index') }}" class="btn btn-sm btn-ghost">← Control deck</a>
                            {% if canAdd %}
                                <form method="post" action="{{ path('app_admin_founder_new') }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('founder_new') }}">
                                    <button class="btn btn-sm btn-primary">+ Add founder</button>
                                </form>
                            {% endif %}
                        </div>
                    </div>
                    <p class="text-xs ia-text-gray mb-3">
                        These are the {{ founders|length }} options on every round's ballot (max {{ max }}).
                        Editing names re-syncs all rounds automatically. Order = ballot order.
                    </p>

                    <div class="flex flex-col gap-2">
                        {% for f in founders %}
                            {% set photo = f.hasHeadshot ? path('app_founder_photo', {'id': f.id}) ~ '?v=' ~ f.version : '/img/founders/f' ~ f.position ~ '.svg' %}
                            <div class="flex items-center gap-3 p-3 bg-base-100 border border-base-300">
                                <div class="text-lg font-display w-6 text-center shrink-0" style="font-weight:200;">{{ f.position }}</div>
                                <img src="{{ photo }}" alt="{{ f.name }}" class="w-14 h-14 shrink-0 rounded-full object-cover border-2 border-base-300 bg-base-200">
                                <div class="flex-1 min-w-0">
                                    <div class="font-semibold truncate">{{ f.name }}</div>
                                    <div class="text-xs ia-text-gray truncate">{{ f.company ?: '—' }}</div>
                                    <div class="text-[11px] ia-text-cyan truncate">Charity: {{ f.charity ?: '—' }}</div>
                                </div>
                                <div class="shrink-0 flex gap-1">
                                    <a href="{{ path('app_admin_founder_edit', {'id': f.id}) }}" class="btn btn-xs btn-ghost">Edit</a>
                                    <button type="button" class="btn btn-xs btn-ghost text-error" onclick="founder_delete_{{ f.id }}.showModal()">Delete</button>
                                </div>
                            </div>
                        {% endfor %}
                    </div>

                    {% if not canAdd %}
                        <p class="text-xs text-warning mt-3">Ballot is full at {{ max }} founders. Delete one to add another.</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    {% for f in founders %}
        <dialog id="founder_delete_{{ f.id }}" class="modal">
            <div class="modal-box">
                <h3 class="font-bold text-lg">Remove {{ f.name }}?</h3>
                <p class="py-4 text-sm">This removes the founder from the ballot and re-numbers the rest. If a game is in progress, reset it afterwards so the choice order stays correct.</p>
                <div class="modal-action">
                    <form method="dialog"><button class="btn btn-ghost">Cancel</button></form>
                    <form method="post" action="{{ path('app_admin_founder_delete', {'id': f.id}) }}" class="inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('founder_delete' ~ f.id) }}">
                        <button class="btn btn-error">Remove founder</button>
                    </form>
                </div>
            </div>
            <form method="dialog" class="modal-backdrop"><button>close</button></form>
        </dialog>
    {% endfor %}
{% endblock %}
