{% extends 'base.html.twig' %}

{% block title %}Edit Founder — Around the Horn{% endblock %}

{% block body %}
    {% include 'components/_brand_header.html.twig' with {'heading': 'Edit Founder', 'subtitle': 'Moderator control'} %}

    <div class="min-h-screen">
        <div class="container mx-auto px-2 py-4 max-w-xl">
            <div class="card bg-base-200 shadow-xl">
                <div class="card-body p-4">
                    <div class="flex items-center gap-3 mb-3">
                        {% set photo = founder.hasHeadshot ? path('app_founder_photo', {'id': founder.id}) ~ '?v=' ~ founder.version : '/img/founders/f' ~ founder.position ~ '.svg' %}
                        <img src="{{ photo }}" alt="{{ founder.name }}" class="w-16 h-16 rounded-full object-cover border-2 border-base-300 bg-base-200">
                        <div>
                            <h2 class="text-lg font-bold">Founder {{ founder.position }}</h2>
                            <p class="text-xs ia-text-gray">Ballot choice {{ founder.position }} on every round</p>
                        </div>
                    </div>

                    {{ form_start(form, {'attr': {'class': 'space-y-3'}}) }}
                        <div class="form-control">
                            {{ form_label(form.name, null, {'label_attr': {'class': 'label py-1 text-sm'}}) }}
                            {{ form_widget(form.name, {'attr': {'class': 'input input-bordered input-sm w-full'}}) }}
                            {{ form_errors(form.name) }}
                        </div>
                        <div class="form-control">
                            {{ form_label(form.company, null, {'label_attr': {'class': 'label py-1 text-sm'}}) }}
                            {{ form_widget(form.company, {'attr': {'class': 'input input-bordered input-sm w-full', 'placeholder': 'e.g. Founder & CEO, Lumen Health'}}) }}
                            {{ form_errors(form.company) }}
                        </div>
                        <div class="form-control">
                            {{ form_label(form.charity, null, {'label_attr': {'class': 'label py-1 text-sm'}}) }}
                            {{ form_widget(form.charity, {'attr': {'class': 'input input-bordered input-sm w-full', 'placeholder': 'e.g. Alabama Farmers Feeding Families'}}) }}
                            {{ form_errors(form.charity) }}
                        </div>
                        <div class="form-control">
                            {{ form_label(form.headshotFile, null, {'label_attr': {'class': 'label py-1 text-sm'}}) }}
                            {{ form_widget(form.headshotFile, {'attr': {'class': 'file-input file-input-bordered file-input-sm w-full'}}) }}
                            {{ form_errors(form.headshotFile) }}
                            <p class="text-[11px] ia-text-gray mt-1">Leave empty to keep the current headshot. Square images look best.</p>
                        </div>

                        <div class="flex justify-end gap-2 mt-2">
                            <a href="{{ path('app_admin_founders') }}" class="btn btn-ghost btn-sm">Cancel</a>
                            <button type="submit" class="btn btn-primary btn-sm">Save founder</button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
