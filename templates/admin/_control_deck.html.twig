{# Moderator control deck — thumb-first layout for phone use during the show.
   Live actions sit in a fixed bottom dock; question editing lives in a separate
   setup section, not beside per-round controls. #}
{% set controlRounds = controlRounds|default([]) %}
{% set standings = standings|default([]) %}
{% set eventScreen = eventScreen|default('auto') %}
{% set seeded = seeded|default(false) %}
{% set onStage = activePoll is not null %}
{% set liveRound = liveRound|default(null) %}

<div class="admin-deck container mx-auto px-3 pt-2 pb-72"
     x-data="{ selectedId: {{ defaultSelectedId ?? 'null' }} }">

    {% if not seeded %}
        <div class="alert alert-warning text-sm mb-3">
            Rounds not seeded yet. Run <code class="font-mono">php bin/console app:event:setup</code> inside the container.
        </div>
    {% endif %}

    {# --- Now playing (read-only context) ----------------------------------- #}
    <section class="admin-status card bg-base-200 border-2 mb-3" style="border-color: var(--ia-blue);">
        <div class="card-body p-4 gap-3">
            {% if onStage and liveRound %}
                <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0">
                        <p class="text-[11px] uppercase tracking-[0.18em] ia-text-gray mb-1">Now on stage</p>
                        <p class="text-lg font-semibold leading-tight">Round {{ liveRound.number }} · {{ liveRound.label }}</p>
                    </div>
                    {% if liveRound.isVotingOpen %}
                        <span class="badge badge-success badge-lg shrink-0">Voting open</span>
                    {% else %}
                        <span class="badge badge-info badge-lg shrink-0">Preview</span>
                    {% endif %}
                </div>
                <p class="text-base leading-snug">{{ activePoll.votingPrompt }}</p>
            {% else %}
                <p class="text-[11px] uppercase tracking-[0.18em] ia-text-gray mb-1">Stand by</p>
                <p class="text-lg font-semibold leading-tight">No round is live</p>
                <p class="text-sm ia-text-gray">Select a round below, then use <strong>Go LIVE</strong> at the bottom.</p>
            {% endif %}

            <div class="flex flex-wrap items-center gap-x-4 gap-y-2 pt-2 border-t border-base-300 text-sm">
                <div>
                    <span class="ia-text-gray">Big screen:</span>
                    <span class="font-semibold uppercase">{{ eventScreen }}</span>
                </div>
                {% if standings|length > 0 %}
                    <div class="flex flex-wrap items-center gap-2">
                        <span class="ia-text-gray">Score:</span>
                        {% for s in standings %}
                            <span class="text-base font-bold">{{ s.founder.initials }} {{ s.points }}</span>{% if not loop.last %}<span class="ia-text-gray">·</span>{% endif %}
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </section>

    {# --- Setup (collapsed — edit copy before / between shows) -------------- #}
    <details class="admin-setup group border-2 border-base-300 bg-base-100 mb-4">
        <summary class="admin-setup-summary cursor-pointer select-none px-4 py-3 text-sm font-semibold uppercase tracking-wide">
            Setup — edit questions &amp; founders
        </summary>
        <div class="px-4 pb-4 pt-1 border-t border-base-300 space-y-4">
            <p class="text-xs ia-text-gray leading-relaxed">
                Open this before the show or between games. You don’t need it while you’re running a round.
            </p>

            <div>
                <p class="text-[11px] uppercase tracking-[0.16em] ia-text-gray mb-2">Round questions</p>
                <div class="flex flex-col gap-2">
                    {% for r in controlRounds %}
                        {% if r.poll %}
                            <a href="{{ path('app_admin_round_edit', {'id': r.poll.id}) }}"
                               class="btn btn-outline justify-start h-auto min-h-12 py-2 text-left normal-case">
                                <span class="font-bold mr-2">R{{ r.number }}</span>
                                <span class="truncate">{{ r.label }}</span>
                            </a>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>

            <div class="flex flex-col gap-2">
                <a href="{{ path('app_admin_founders') }}" class="btn btn-outline justify-start min-h-12">Manage founders</a>
                <form method="post" action="{{ path('app_admin_round_new') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('round_new') }}">
                    <button type="submit" class="btn btn-outline w-full min-h-12">+ Add round</button>
                </form>
            </div>

            <div class="flex flex-col gap-2">
                <a href="{{ path('app_obs') }}" target="_blank" rel="noopener" class="btn btn-ghost btn-sm justify-start">Open LED wall (/obs) ↗</a>
                <a href="{{ path('app_obs_qr') }}" target="_blank" rel="noopener" class="btn btn-ghost btn-sm justify-start">Open QR display (/obs/qr) ↗</a>
                <a href="{{ path('app_admin_account') }}" class="btn btn-ghost btn-sm justify-start">Change password</a>
            </div>

            <div class="pt-2 border-t border-base-300">
                <p class="text-[11px] uppercase tracking-[0.16em] ia-text-gray mb-2">Danger zone</p>
                <div class="flex flex-col gap-2">
                    {% for r in controlRounds %}
                        {% if r.poll %}
                            <button type="button"
                                    class="btn btn-ghost btn-sm justify-start text-error"
                                    onclick="round_delete_{{ r.poll.id }}.showModal()">
                                Delete round {{ r.number }}
                            </button>
                        {% endif %}
                    {% endfor %}
                    <button type="button" class="btn btn-error btn-outline min-h-12" onclick="event_reset_modal.showModal()">
                        Reset / new game
                    </button>
                </div>
            </div>
        </div>
    </details>

    {# --- Round roster (status + pick next round) --------------------------- #}
    <section class="mb-3">
        <h2 class="text-[11px] uppercase tracking-[0.18em] ia-text-gray mb-2 px-1">Rounds</h2>
        <div class="flex flex-col gap-2">
            {% for r in controlRounds %}
                {% if r.poll %}
                    {% if onStage %}
                        <div class="admin-round-row {% if r.isActive %}admin-round-row--live{% endif %}">
                            <div class="admin-round-num">{{ r.number }}</div>
                            <div class="admin-round-body">
                                <div class="font-semibold leading-tight">{{ r.label }}</div>
                                <div class="admin-round-badges">
                                    {% if r.isVotingOpen %}<span class="badge badge-success">Voting</span>
                                    {% elseif r.isActive %}<span class="badge badge-info">On stage</span>
                                    {% elseif r.isDecided %}<span class="badge badge-neutral">Closed</span>
                                    {% else %}<span class="badge badge-ghost">Ready</span>{% endif %}
                                    <span class="badge badge-outline">{{ r.votes }} votes</span>
                                </div>
                            </div>
                        </div>
                    {% else %}
                        <button type="button"
                                class="admin-round-row w-full text-left"
                                :class="{ 'admin-round-row--selected': selectedId === {{ r.poll.id }} }"
                                @click="selectedId = {{ r.poll.id }}"
                                {% if r.isDecided %}disabled{% endif %}>
                            <div class="admin-round-num">{{ r.number }}</div>
                            <div class="admin-round-body">
                                <div class="font-semibold leading-tight">{{ r.label }}</div>
                                <div class="admin-round-badges">
                                    {% if r.isDecided %}<span class="badge badge-neutral">Closed</span>
                                    {% else %}<span class="badge badge-ghost">Ready</span>{% endif %}
                                    <span class="badge badge-outline">{{ r.votes }} votes</span>
                                </div>
                            </div>
                        </button>
                    {% endif %}
                {% else %}
                    <div class="admin-round-row opacity-60">
                        <div class="admin-round-num">{{ r.number }}</div>
                        <div class="admin-round-body">
                            <div class="font-semibold">{{ r.label }}</div>
                            <span class="badge badge-warning badge-sm">Not seeded</span>
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
        </div>
    </section>
</div>

{# --- Fixed bottom dock (live controls — thumb reach) --------------------- #}
<div class="admin-dock">
    <div class="admin-dock-inner container mx-auto px-3 max-w-xl">
        <p class="admin-dock-label text-[10px] uppercase tracking-[0.2em] ia-text-gray text-center mb-2">Live controls</p>

        {% for r in controlRounds %}
            {% if r.poll %}
                <div x-show="{{ onStage ? (r.isActive ? 'true' : 'false') : ('selectedId === ' ~ r.poll.id) }}"
                     x-cloak
                     class="admin-dock-round space-y-2">
                    {% if r.isActive %}
                        {% if r.isVotingOpen %}
                            <form method="post" action="{{ path('app_admin_round_close', {'id': r.poll.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('round' ~ r.poll.id) }}">
                                <button type="submit" class="btn btn-neutral btn-lg w-full text-lg min-h-14">Close round</button>
                            </form>
                        {% else %}
                            <form method="post" action="{{ path('app_admin_round_open_vote', {'id': r.poll.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('round' ~ r.poll.id) }}">
                                <button type="submit" class="btn btn-primary btn-lg w-full text-lg min-h-14">Open vote</button>
                            </form>
                            <form method="post" action="{{ path('app_admin_round_close', {'id': r.poll.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('round' ~ r.poll.id) }}">
                                <button type="submit" class="btn btn-outline w-full min-h-12">Cancel preview</button>
                            </form>
                        {% endif %}
                    {% elseif not r.isDecided %}
                        <form method="post" action="{{ path('app_admin_round_activate', {'id': r.poll.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('round' ~ r.poll.id) }}">
                            <button type="submit" class="btn btn-primary btn-lg w-full text-lg min-h-14">
                                Go LIVE — Round {{ r.number }}
                            </button>
                        </form>
                    {% else %}
                        <p class="text-center text-sm ia-text-gray py-3">This round is closed. Pick another round above.</p>
                    {% endif %}
                </div>
            {% endif %}
        {% endfor %}

        <div x-show="!{{ onStage ? 'true' : 'false' }} && selectedId === null" x-cloak class="text-center text-sm ia-text-gray py-3">
            Tap a round above to continue.
        </div>

        <div class="admin-dock-screen grid grid-cols-3 gap-2 mt-3 pt-3 border-t border-base-300">
            <form method="post" action="{{ path('app_admin_event_screen', {'screen': 'winner'}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('event_screen') }}">
                <button type="submit" class="btn btn-neutral w-full min-h-12 text-sm leading-tight">Reveal winner</button>
            </form>
            <form method="post" action="{{ path('app_admin_event_screen', {'screen': 'auto'}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('event_screen') }}">
                <button type="submit" class="btn btn-outline w-full min-h-12 text-sm leading-tight">Resume live</button>
            </form>
            <form method="post" action="{{ path('app_admin_event_screen', {'screen': 'intro'}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('event_screen') }}">
                <button type="submit" class="btn btn-outline w-full min-h-12 text-sm leading-tight">Intro</button>
            </form>
        </div>

        <div class="admin-dock-theme grid grid-cols-2 gap-2 mt-2">
            <form method="post" action="{{ path('app_admin_event_theme', {'theme': 'innovate'}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('event_theme') }}">
                <button type="submit" class="btn btn-sm w-full min-h-10 {% if event_state.theme != 'innovate-dark' %}btn-primary{% else %}btn-ghost{% endif %}">Light theme</button>
            </form>
            <form method="post" action="{{ path('app_admin_event_theme', {'theme': 'innovate-dark'}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('event_theme') }}">
                <button type="submit" class="btn btn-sm w-full min-h-10 {% if event_state.theme == 'innovate-dark' %}btn-primary{% else %}btn-ghost{% endif %}">Dark theme</button>
            </form>
        </div>
    </div>
</div>

{# Reset / new-game confirmation #}
<dialog id="event_reset_modal" class="modal">
    <div class="modal-box">
        <h3 class="font-bold text-lg">Reset for a new game?</h3>
        <p class="py-4 text-sm">This clears <b>all votes</b> from every round, sets every round back to Draft, and returns the OBS display to the intro screen. The rounds and their wording are kept. This cannot be undone.</p>
        <div class="modal-action">
            <form method="dialog"><button class="btn btn-ghost">Cancel</button></form>
            <form method="post" action="{{ path('app_admin_event_reset') }}" class="inline">
                <input type="hidden" name="_token" value="{{ csrf_token('event_reset') }}">
                <button class="btn btn-error">Reset &amp; start new game</button>
            </form>
        </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

{# Per-round delete confirmation #}
{% for r in controlRounds %}
    {% if r.poll %}
        <dialog id="round_delete_{{ r.poll.id }}" class="modal">
            <div class="modal-box">
                <h3 class="font-bold text-lg">Delete Round {{ r.number }}?</h3>
                <p class="py-4 text-sm">This permanently removes the round "{{ r.label }}"{% if r.votes > 0 %} and its {{ r.votes }} vote(s){% endif %}. This cannot be undone.</p>
                <div class="modal-action">
                    <form method="dialog"><button class="btn btn-ghost">Cancel</button></form>
                    <form method="post" action="{{ path('app_admin_delete', {'id': r.poll.id}) }}" class="inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ r.poll.id) }}">
                        <button class="btn btn-error">Delete round</button>
                    </form>
                </div>
            </div>
            <form method="dialog" class="modal-backdrop"><button>close</button></form>
        </dialog>
    {% endif %}
{% endfor %}
