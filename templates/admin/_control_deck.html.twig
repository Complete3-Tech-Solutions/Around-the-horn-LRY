{# Moderator control deck — phone-first, single-thumb operation.
   The moderator runs this from a phone WHILE talking on stage, so:
   • the one action that matters right now is the biggest thing on screen
     (sticky bottom dock while a round is live, big Go LIVE card while idle);
   • the live round + score sit at the very top — no scrolling to act;
   • everything he only touches before/after the show (theme, copy, founders)
     is collapsed under "Settings", and the destructive stuff under
     "Danger zone" — both pushed to the bottom so they can't be hit by mistake. #}
{% set controlRounds = controlRounds|default([]) %}
{% set standings = standings|default([]) %}
{% set eventScreen = eventScreen|default('auto') %}
{% set seeded = seeded|default(false) %}
{% set onStage = activePoll is not null %}
{% set currentTheme = event_state.theme %}
{% set totalRounds = controlRounds|length %}

{# Derive the live round + the next round to start straight from controlRounds,
   so this template needs nothing extra from the controller. #}
{% set liveRound = null %}
{% set nextUp = null %}
{% for r in controlRounds %}
    {% if r.isActive %}{% set liveRound = r %}{% endif %}
    {% if nextUp is null and r.poll and not r.isActive and not r.isDecided %}{% set nextUp = r %}{% endif %}
{% endfor %}

<div class="admin-deck container mx-auto px-3 py-4 max-w-xl pb-8">

    {% if not seeded %}
        <div class="alert alert-warning text-sm mb-6">
            Rounds not seeded yet. Run <code class="font-mono">php bin/console app:event:setup</code> inside the container.
        </div>
    {% endif %}

    {# NOW — the single most important thing on screen ---------------------- #}
    <section class="card bg-base-200 border-2 mb-6" style="border-color: var(--ia-blue);">
        <div class="card-body p-5 gap-4">
            {% if onStage and liveRound %}
                {% if liveRound.isVotingOpen %}
                    <div class="flex flex-wrap items-center gap-3">
                        <span class="badge badge-success badge-lg gap-2"><span class="ia-live-dot"></span>Voting open</span>
                        <span class="text-lg font-semibold">Round {{ liveRound.number }} of {{ totalRounds }}</span>
                    </div>
                    <p class="text-base leading-relaxed">{{ activePoll.votingPrompt }}</p>
                    <div class="flex items-baseline gap-2">
                        <span class="text-5xl font-display leading-none" style="font-weight:200;">{{ liveRound.votes }}</span>
                        <span class="text-sm ia-text-gray">votes in</span>
                    </div>
                    <p class="text-sm ia-text-gray">When the debate’s done, tap <strong>Close round</strong> on Round {{ liveRound.number }} below.</p>
                {% else %}
                    <div class="flex flex-wrap items-center gap-3">
                        <span class="badge badge-info badge-lg">On stage</span>
                        <span class="text-lg font-semibold">Round {{ liveRound.number }} of {{ totalRounds }}</span>
                    </div>
                    <p class="text-base leading-relaxed">{{ activePoll.votingPrompt }}</p>
                    <p class="text-sm ia-text-gray">Audience can’t vote yet — tap <strong>Open vote</strong> on Round {{ liveRound.number }} below to start.</p>
                {% endif %}
            {% elseif nextUp %}
                <p class="text-xs uppercase tracking-wide ia-text-gray">Up next — Round {{ nextUp.number }} of {{ totalRounds }}</p>
                <p class="text-xl font-semibold leading-tight">{{ nextUp.label }}</p>
                {% if nextUp.title %}<p class="text-sm ia-text-gray leading-relaxed">{{ nextUp.title }}</p>{% endif %}
                <form method="post" action="{{ path('app_admin_round_activate', {'id': nextUp.poll.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('round' ~ nextUp.poll.id) }}">
                    <button type="submit" class="btn btn-primary btn-lg w-full min-h-16 text-xl">Go LIVE — Round {{ nextUp.number }}</button>
                </form>
            {% else %}
                <p class="text-xl font-semibold">All rounds complete 🎉</p>
                <p class="text-sm ia-text-gray">Reveal the winner on the big screen.</p>
                <form method="post" action="{{ path('app_admin_event_screen', {'screen': 'winner'}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('event_screen') }}">
                    <button type="submit" class="btn btn-primary btn-lg w-full min-h-16 text-xl">Reveal winner</button>
                </form>
            {% endif %}

            <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm pt-3 border-t border-base-300">
                <div><span class="ia-text-gray">Big screen:</span> <strong class="uppercase">{{ eventScreen }}</strong></div>
                {% if standings|length > 0 %}
                    <div class="flex flex-wrap gap-2">
                        <span class="ia-text-gray">Score</span>
                        {% for s in standings %}
                            <strong>{{ s.founder.initials }} {{ s.points }}</strong>{% if not loop.last %}<span class="ia-text-gray">·</span>{% endif %}
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </section>

    {# Rounds — quick status + jump to any round --------------------------- #}
    <section class="mb-6">
        <h2 class="text-sm font-semibold uppercase tracking-wide mb-4">Rounds</h2>
        <div class="flex flex-col gap-3">
            {% for r in controlRounds %}
                <div class="card bg-base-100 border-2 {% if r.isActive %}border-primary{% else %}border-base-300{% endif %}">
                    <div class="card-body p-4 gap-3">
                        <div class="flex items-start gap-4">
                            <div class="text-3xl font-display w-10 text-center shrink-0" style="font-weight:200;">{{ r.number }}</div>
                            <div class="min-w-0 flex-1">
                                <div class="text-base font-semibold leading-tight">{{ r.label }}</div>
                                <div class="flex flex-wrap gap-2 mt-2">
                                    {% if r.isVotingOpen %}<span class="badge badge-success">Voting</span>
                                    {% elseif r.isActive %}<span class="badge badge-info">On stage</span>
                                    {% elseif r.isDecided %}<span class="badge badge-neutral">Closed</span>
                                    {% elseif r.poll %}<span class="badge badge-ghost">Ready</span>
                                    {% else %}<span class="badge badge-warning">Not seeded</span>{% endif %}
                                    {% if r.poll %}<span class="badge badge-outline">{{ r.votes }} votes</span>{% endif %}
                                </div>
                            </div>
                        </div>

                        {# Live action stays right here on the active round's card —
                           no separate dock popping up at the bottom. #}
                        {% if r.isActive %}
                            {% if r.isVotingOpen %}
                                <form method="post" action="{{ path('app_admin_round_close', {'id': r.poll.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('round' ~ r.poll.id) }}">
                                    <button type="submit" class="btn btn-neutral btn-lg w-full min-h-16 text-xl">Close round</button>
                                </form>
                            {% else %}
                                <form method="post" action="{{ path('app_admin_round_open_vote', {'id': r.poll.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('round' ~ r.poll.id) }}">
                                    <button type="submit" class="btn btn-primary btn-lg w-full min-h-16 text-xl">Open vote</button>
                                </form>
                                <form method="post" action="{{ path('app_admin_round_close', {'id': r.poll.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('round' ~ r.poll.id) }}">
                                    <button type="submit" class="btn btn-ghost btn-sm w-full">Cancel preview</button>
                                </form>
                            {% endif %}
                        {% elseif r.poll and not r.isDecided %}
                            <form method="post" action="{{ path('app_admin_round_activate', {'id': r.poll.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('round' ~ r.poll.id) }}">
                                <button type="submit" class="btn btn-outline btn-primary w-full min-h-12">
                                    {% if onStage %}Switch to this round{% else %}Go LIVE{% endif %}
                                </button>
                            </form>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    </section>

    {# Big screen — used live at the end, kept reachable ------------------- #}
    <section class="card bg-base-100 border-2 border-base-300 mb-8">
        <div class="card-body p-5 gap-4">
            <h2 class="text-sm font-semibold uppercase tracking-wide">Big screen</h2>
            <div class="flex flex-col gap-3">
                <form method="post" action="{{ path('app_admin_event_screen', {'screen': 'winner'}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('event_screen') }}">
                    <button type="submit" class="btn btn-neutral btn-lg w-full min-h-14">Reveal winner</button>
                </form>
                <div class="grid grid-cols-2 gap-3">
                    <form method="post" action="{{ path('app_admin_event_screen', {'screen': 'auto'}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('event_screen') }}">
                        <button type="submit" class="btn btn-outline btn-lg w-full min-h-14">Resume live</button>
                    </form>
                    <form method="post" action="{{ path('app_admin_event_screen', {'screen': 'intro'}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('event_screen') }}">
                        <button type="submit" class="btn btn-outline btn-lg w-full min-h-14">Intro screen</button>
                    </form>
                </div>
            </div>
        </div>
    </section>

    {# ===================================================================== #}
    {# Below here is pre/post-show only — sent down + collapsed.             #}
    {# ===================================================================== #}

    {# Settings — theme + copy + roster ----------------------------------- #}
    <details class="admin-setup border-2 border-base-300 bg-base-100 mb-4">
        <summary class="admin-setup-summary cursor-pointer select-none px-5 py-4 text-sm font-semibold uppercase tracking-wide">
            Settings
        </summary>
        <div class="px-5 pb-5 pt-2 border-t border-base-300 flex flex-col gap-6">
            <p class="text-sm ia-text-gray">Set these before the show — you won’t need them while running a round.</p>

            {# Theme #}
            <div class="flex flex-col gap-3">
                <p class="text-xs uppercase tracking-wide ia-text-gray">Display theme — currently {{ currentTheme == 'innovate-dark' ? 'Dark' : 'Light' }}</p>
                <div class="grid grid-cols-2 gap-3">
                    <form method="post" action="{{ path('app_admin_event_theme', {'theme': 'innovate'}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('event_theme') }}">
                        <button type="submit" class="btn btn-lg w-full min-h-14 {{ currentTheme != 'innovate-dark' ? 'btn-primary' : 'btn-outline' }}">Light</button>
                    </form>
                    <form method="post" action="{{ path('app_admin_event_theme', {'theme': 'innovate-dark'}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('event_theme') }}">
                        <button type="submit" class="btn btn-lg w-full min-h-14 {{ currentTheme == 'innovate-dark' ? 'btn-primary' : 'btn-outline' }}">Dark</button>
                    </form>
                </div>
            </div>

            {# Round copy #}
            <div class="flex flex-col gap-3 pt-2 border-t border-base-300">
                <p class="text-xs uppercase tracking-wide ia-text-gray">Edit round questions</p>
                {% for r in controlRounds %}
                    {% if r.poll %}
                        <a href="{{ path('app_admin_round_edit', {'id': r.poll.id}) }}"
                           class="btn btn-outline btn-lg w-full justify-start min-h-14 normal-case">
                            Round {{ r.number }} — {{ r.label }}
                        </a>
                    {% endif %}
                {% endfor %}
            </div>

            {# Roster + utilities #}
            <div class="flex flex-col gap-3 pt-2 border-t border-base-300">
                <a href="{{ path('app_admin_founders') }}" class="btn btn-outline btn-lg w-full min-h-14">Manage founders</a>
                <form method="post" action="{{ path('app_admin_round_new') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('round_new') }}">
                    <button type="submit" class="btn btn-outline btn-lg w-full min-h-14">+ Add round</button>
                </form>
                <a href="{{ path('app_obs') }}" target="_blank" rel="noopener" class="btn btn-ghost w-full justify-start">Open LED wall ↗</a>
                <a href="{{ path('app_obs_qr') }}" target="_blank" rel="noopener" class="btn btn-ghost w-full justify-start">Open QR display ↗</a>
                <a href="{{ path('app_admin_account') }}" class="btn btn-ghost w-full justify-start">Change password</a>
            </div>
        </div>
    </details>

    {# Danger zone — collapsed, isolated, last ---------------------------- #}
    <details class="admin-setup admin-danger border-2 bg-base-100 mb-6">
        <summary class="admin-setup-summary cursor-pointer select-none px-5 py-4 text-sm font-semibold uppercase tracking-wide text-error">
            Danger zone
        </summary>
        <div class="px-5 pb-5 pt-2 border-t border-base-300 flex flex-col gap-3">
            <p class="text-sm ia-text-gray">Destructive and can’t be undone — don’t tap during the show.</p>
            <button type="button" class="btn btn-error btn-lg w-full min-h-14" onclick="event_reset_modal.showModal()">
                Reset / new game
            </button>
            {% for r in controlRounds %}
                {% if r.poll %}
                    <button type="button" class="btn btn-ghost w-full justify-start text-error"
                            onclick="round_delete_{{ r.poll.id }}.showModal()">Delete round {{ r.number }} — {{ r.label }}</button>
                {% endif %}
            {% endfor %}
        </div>
    </details>
</div>

{# Reset / new-game confirmation #}
<dialog id="event_reset_modal" class="modal">
    <div class="modal-box">
        <h3 class="font-bold text-lg">Reset for a new game?</h3>
        <p class="py-4 text-sm">This clears <b>all votes</b> from every round, sets every round back to Draft, and returns the OBS display to the intro screen. The rounds and their wording are kept. This cannot be undone.</p>
        <div class="modal-action">
            <form method="dialog"><button class="btn btn-ghost">Cancel</button></form>
            <form method="post" action="{{ path('app_admin_event_reset') }}" class="inline">
                <input type="hidden" name="_token" value="{{ csrf_token('event_reset') }}">
                <button class="btn btn-error">Reset &amp; start new game</button>
            </form>
        </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

{# Per-round delete confirmation #}
{% for r in controlRounds %}
    {% if r.poll %}
        <dialog id="round_delete_{{ r.poll.id }}" class="modal">
            <div class="modal-box">
                <h3 class="font-bold text-lg">Delete Round {{ r.number }}?</h3>
                <p class="py-4 text-sm">This permanently removes the round "{{ r.label }}"{% if r.votes > 0 %} and its {{ r.votes }} vote(s){% endif %}. This cannot be undone.</p>
                <div class="modal-action">
                    <form method="dialog"><button class="btn btn-ghost">Cancel</button></form>
                    <form method="post" action="{{ path('app_admin_delete', {'id': r.poll.id}) }}" class="inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ r.poll.id) }}">
                        <button class="btn btn-error">Delete round</button>
                    </form>
                </div>
            </div>
            <form method="dialog" class="modal-backdrop"><button>close</button></form>
        </dialog>
    {% endif %}
{% endfor %}
