{# Moderator control deck — phone-first, single-thumb operation.
   The moderator runs this from a phone WHILE talking on stage, so:
   • the one action that matters right now is the biggest thing on screen
     (sticky bottom dock while a round is live, big Go LIVE card while idle);
   • the live round + score sit at the very top — no scrolling to act;
   • everything he only touches before/after the show (theme, copy, founders)
     is collapsed under "Settings", and the destructive stuff under
     "Danger zone" — both pushed to the bottom so they can't be hit by mistake. #}
{% set controlRounds = controlRounds|default([]) %}
{% set seeded = seeded|default(false) %}
{% set currentTheme = event_state.theme %}

<div class="admin-deck container mx-auto px-3 py-4 max-w-xl pb-8">

    {% if not seeded %}
        <div class="alert alert-warning text-sm mb-6">
            Rounds not seeded yet. Run <code class="font-mono">php bin/console app:event:setup</code> inside the container.
        </div>
    {% endif %}

    {# Live region (on-stage box, big screen, rounds). Self-refreshes via HTMX
       while a round is on stage — see admin/_control_live.html.twig. #}
    {{ include('admin/_control_live.html.twig') }}

    {# ===================================================================== #}
    {# Below here is pre/post-show only — sent down + collapsed.             #}
    {# ===================================================================== #}

    {# Settings — theme + copy + roster ----------------------------------- #}
    <details class="admin-setup border-2 border-base-300 bg-base-100 mb-4">
        <summary class="admin-setup-summary cursor-pointer select-none px-5 py-4 text-sm font-semibold uppercase tracking-wide">
            Settings
        </summary>
        <div class="px-5 pb-5 pt-2 border-t border-base-300 flex flex-col gap-6">
            <p class="text-sm ia-text-gray">Set these before the show — you won’t need them while running a round.</p>

            {# Theme #}
            <div class="flex flex-col gap-3">
                <p class="text-xs uppercase tracking-wide ia-text-gray">Display theme — currently {{ currentTheme == 'innovate-dark' ? 'Dark' : 'Light' }}</p>
                <div class="grid grid-cols-2 gap-3">
                    <form method="post" action="{{ path('app_admin_event_theme', {'theme': 'innovate'}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('event_theme') }}">
                        <button type="submit" class="btn btn-lg w-full min-h-14 {{ currentTheme != 'innovate-dark' ? 'btn-primary' : 'btn-outline' }}">Light</button>
                    </form>
                    <form method="post" action="{{ path('app_admin_event_theme', {'theme': 'innovate-dark'}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('event_theme') }}">
                        <button type="submit" class="btn btn-lg w-full min-h-14 {{ currentTheme == 'innovate-dark' ? 'btn-primary' : 'btn-outline' }}">Dark</button>
                    </form>
                </div>
            </div>

            {# Round copy #}
            <div class="flex flex-col gap-3 pt-2 border-t border-base-300">
                <p class="text-xs uppercase tracking-wide ia-text-gray">Edit round questions</p>
                {% for r in controlRounds %}
                    {% if r.poll %}
                        <a href="{{ path('app_admin_round_edit', {'id': r.poll.id}) }}"
                           class="btn btn-outline btn-lg w-full justify-start min-h-14 normal-case">
                            Round {{ r.number }} — {{ r.label }}
                        </a>
                    {% endif %}
                {% endfor %}
            </div>

            {# Roster + utilities #}
            <div class="flex flex-col gap-3 pt-2 border-t border-base-300">
                <a href="{{ path('app_admin_founders') }}" class="btn btn-outline btn-lg w-full min-h-14">Manage founders</a>
                <form method="post" action="{{ path('app_admin_round_new') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('round_new') }}">
                    <button type="submit" class="btn btn-outline btn-lg w-full min-h-14">+ Add round</button>
                </form>
                <a href="{{ path('app_obs') }}" target="_blank" rel="noopener" class="btn btn-ghost w-full justify-start">Open LED wall ↗</a>
                <a href="{{ path('app_obs_qr') }}" target="_blank" rel="noopener" class="btn btn-ghost w-full justify-start">Open QR display ↗</a>
                <a href="{{ path('app_admin_account') }}" class="btn btn-ghost w-full justify-start">Change password</a>
            </div>
        </div>
    </details>

    {# Danger zone — collapsed, isolated, last ---------------------------- #}
    <details class="admin-setup admin-danger border-2 bg-base-100 mb-6">
        <summary class="admin-setup-summary cursor-pointer select-none px-5 py-4 text-sm font-semibold uppercase tracking-wide text-error">
            Danger zone
        </summary>
        <div class="px-5 pb-5 pt-2 border-t border-base-300 flex flex-col gap-3">
            <p class="text-sm ia-text-gray">Destructive and can’t be undone — don’t tap during the show.</p>
            <button type="button" class="btn btn-error btn-lg w-full min-h-14" onclick="event_reset_modal.showModal()">
                Reset / new game
            </button>
            {% for r in controlRounds %}
                {% if r.poll %}
                    <button type="button" class="btn btn-ghost w-full justify-start text-error"
                            onclick="round_delete_{{ r.poll.id }}.showModal()">Delete round {{ r.number }} — {{ r.label }}</button>
                {% endif %}
            {% endfor %}
        </div>
    </details>
</div>

{# Reset / new-game confirmation #}
<dialog id="event_reset_modal" class="modal">
    <div class="modal-box">
        <h3 class="font-bold text-lg">Reset for a new game?</h3>
        <p class="py-4 text-sm">This clears <b>all votes</b> from every round, sets every round back to Draft, and returns the OBS display to the intro screen. The rounds and their wording are kept. This cannot be undone.</p>
        <div class="modal-action">
            <form method="dialog"><button class="btn btn-ghost">Cancel</button></form>
            <form method="post" action="{{ path('app_admin_event_reset') }}" class="inline">
                <input type="hidden" name="_token" value="{{ csrf_token('event_reset') }}">
                <button class="btn btn-error">Reset &amp; start new game</button>
            </form>
        </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

{# Per-round delete confirmation #}
{% for r in controlRounds %}
    {% if r.poll %}
        <dialog id="round_delete_{{ r.poll.id }}" class="modal">
            <div class="modal-box">
                <h3 class="font-bold text-lg">Delete Round {{ r.number }}?</h3>
                <p class="py-4 text-sm">This permanently removes the round "{{ r.label }}"{% if r.votes > 0 %} and its {{ r.votes }} vote(s){% endif %}. This cannot be undone.</p>
                <div class="modal-action">
                    <form method="dialog"><button class="btn btn-ghost">Cancel</button></form>
                    <form method="post" action="{{ path('app_admin_delete', {'id': r.poll.id}) }}" class="inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ r.poll.id) }}">
                        <button class="btn btn-error">Delete round</button>
                    </form>
                </div>
            </div>
            <form method="dialog" class="modal-backdrop"><button>close</button></form>
        </dialog>
    {% endif %}
{% endfor %}
