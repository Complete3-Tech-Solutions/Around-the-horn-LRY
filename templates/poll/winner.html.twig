{% extends 'base.html.twig' %}

{% block title %}Champion — Around the Horn{% endblock %}

{% block body %}
{% set champion = champion|default(null) %}
{% set standings = standings|default([]) %}
{% set topPoints = standings|length > 0 ? standings[0].points : 0 %}

{# Self-polling shell — when the moderator hits "Resume live" the screen flag
   clears and this re-polls back to the ballot/standby. Never hx-select "body". #}
<div id="vote-app" class="ia-stage"
     hx-get="{{ path('app_vote_live') }}"
     hx-trigger="every 3s"
     hx-select="#vote-app"
     hx-swap="outerHTML">

    {% include 'components/_brand_header.html.twig' with {
        'compact': true,
        'stage': true,
        'subtitle': 'Audience voting',
        'badge': 'Champion',
    } %}

    <div class="min-h-screen bg-base-100 grid place-items-center px-3 py-9 relative overflow-hidden">
        <div class="fireworks-container absolute inset-0 pointer-events-none"></div>

        <div class="max-w-md w-full relative z-10 border-2 border-base-300 bg-base-100">
            <div class="border-b-2 border-base-300 px-4 py-3 text-center">
                <span class="text-[11px] uppercase tracking-[0.3em] font-bold" style="color: var(--ia-cyan);">★ Audience Champion ★</span>
            </div>

            <div class="px-4 py-6 text-center">
                {% if champion %}
                    <img src="{{ champion.founder.headshot }}" alt="{{ champion.founder.name }}"
                         class="w-24 h-24 mx-auto rounded-full border-2 border-base-300 bg-base-200 object-cover">
                    <h1 class="text-3xl font-display mt-3" style="font-weight:200;">{{ champion.founder.name }}</h1>
                    <p class="text-[11px] uppercase tracking-[0.14em] ia-text-gray mt-1">{{ champion.founder.sector }}</p>
                    {% if champion.tie %}
                        <p class="text-sm mt-2 ia-text-gray">Tie at the top — the moderator makes the call.</p>
                    {% endif %}
                    <p class="text-sm mt-4 leading-snug">The Innovate Alabama donation goes to <b>{{ champion.founder.charity }}</b>.</p>
                {% else %}
                    <h1 class="text-3xl font-display mt-3" style="font-weight:200;">Thanks for voting!</h1>
                    <p class="ia-text-gray text-sm mt-2">Tallying the final results…</p>
                {% endif %}
            </div>

            {% if standings is not empty %}
                <div class="border-t-2 border-base-300">
                    {% for row in standings %}
                        {% set leads = topPoints > 0 and row.points == topPoints %}
                        <div class="flex items-center gap-3 px-4 py-3 {{ not loop.last ? 'border-b border-base-300' : '' }}">
                            <img src="{{ row.founder.headshot }}" alt="{{ row.founder.name }}"
                                 class="w-9 h-9 shrink-0 rounded-full border-2 {{ leads ? 'border-secondary' : 'border-base-300' }} bg-base-200 object-cover">
                            <div class="min-w-0 grow leading-tight">
                                <div class="font-medium truncate">{{ row.founder.name }}</div>
                            </div>
                            {% if leads %}<span class="text-[10px] uppercase tracking-[0.14em] font-bold shrink-0" style="color: var(--ia-cyan);">Winner</span>{% endif %}
                            <span class="font-mono text-2xl leading-none shrink-0 {{ leads ? 'font-bold' : '' }}">{{ row.points }}</span>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}

            <div class="border-t-2 border-base-300 px-4 py-3 text-center">
                <p class="text-[11px] ia-text-gray">Thanks for playing — the results are on the big screen.</p>
            </div>
        </div>
    </div>

    <script>
    (function () {
        const start = () => {
            const c = document.querySelector('.fireworks-container');
            if (c && window.Fireworks && !c.dataset.lit) {
                c.dataset.lit = '1';
                new window.Fireworks(c, { autoresize: true, opacity: 0.5, particles: 60, intensity: 30, hue: { min: 185, max: 215 } }).start();
            }
        };
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', start);
        } else {
            start();
        }
    })();
    </script>
</div>
{% endblock %}
