{% extends 'base.html.twig' %}

{% block title %}Get Ready — Around the Horn{% endblock %}

{% block body %}
{% set round = poll.roundMeta %}
{% set founders = event_config.founders %}
{% set total_rounds = total_rounds|default(0) %}

<div id="vote-app" class="ia-stage"
     hx-get="{{ path('app_vote_live') }}"
     hx-trigger="every 2s"
     hx-select="#vote-app"
     hx-swap="outerHTML">

    {% include 'components/_brand_header.html.twig' with {
        'compact': true,
        'stage': true,
        'subtitle': 'Cast your vote',
        'badge': round ? 'Round ' ~ round.number ~ ' of ' ~ total_rounds : 'Live vote',
    } %}

    <div class="min-h-screen bg-base-100">
        <div class="container mx-auto px-3 max-w-xl pt-5 pb-12">
            <h1 class="text-2xl sm:text-3xl font-display leading-tight mb-3" style="font-weight:200;">{{ poll.votingPrompt }}</h1>
            <p class="text-sm ia-text-gray mb-6 flex items-center gap-2">
                <span class="loading loading-dots loading-xs ia-text-cyan"></span>
                Vote here when voting opens
            </p>

            <div class="grid grid-cols-3 gap-2 sm:gap-3">
                {% for f in founders %}
                    <div class="border-2 border-base-300 p-2 sm:p-3 text-center flex flex-col items-center">
                        <img src="{{ f.headshot }}" alt="{{ f.name }}"
                             class="w-16 h-16 sm:w-20 sm:h-20 shrink-0 border-2 border-base-300 bg-base-200 object-cover">
                        <div class="text-sm sm:text-base font-medium leading-tight mt-2">{{ f.name }}</div>
                        <div class="text-[9px] sm:text-[10px] uppercase tracking-[0.12em] ia-text-gray mt-1 leading-snug">{{ f.sector }}</div>
                    </div>
                {% endfor %}
            </div>

            <p class="mt-6 text-center text-[11px] ia-text-gray leading-snug">
                Keep this page open — voting starts automatically when the moderator opens it.
            </p>
        </div>
    </div>
</div>
{% endblock %}
