{% extends 'base.html.twig' %}

{% block title %}Get Ready — Around the Horn{% endblock %}

{% block body %}
{% set round = poll.roundMeta %}
{% set founders = event_config.founders %}
{% set total_rounds = total_rounds|default(0) %}

<div id="vote-app" class="ia-stage"
     hx-get="{{ path('app_vote_live') }}"
     hx-trigger="every 2s"
     hx-select="#vote-app"
     hx-swap="outerHTML">

    {% include 'components/_brand_header.html.twig' with {
        'compact': true,
        'stage': true,
        'subtitle': 'Cast your vote',
        'badge': round ? 'Round ' ~ round.number ~ ' of ' ~ total_rounds : 'Live vote',
    } %}

    <div class="min-h-screen bg-base-100">
        <div class="container mx-auto px-3 max-w-xl pt-5 pb-12">
            {% set myths = round ? round.myths|default([]) : [] %}
            {% set hasMyths = myths|length > 0 %}
            {% if hasMyths %}
                <h1 class="text-2xl sm:text-3xl font-display leading-tight mb-3" style="font-weight:200;">{{ round.title }}</h1>
                {% include 'components/_myths_list.html.twig' with { myths: myths, variant: 'phone' } %}
                <p class="text-lg font-semibold leading-snug mb-3">{{ poll.votingPrompt }}</p>
            {% else %}
                <h1 class="text-2xl sm:text-3xl font-display leading-tight mb-3" style="font-weight:200;">{{ poll.votingPrompt }}</h1>
            {% endif %}
            <p class="text-sm ia-text-gray mb-6 flex items-center gap-2">
                <span class="loading loading-dots loading-xs ia-text-cyan"></span>
                Vote here when voting opens
            </p>

            {% if not hasMyths %}
            <div class="flex flex-col gap-3">
                {% for f in founders %}
                    <div class="flex items-center gap-3 p-3 border-2 border-base-300 opacity-90">
                        <img src="{{ f.headshot }}" alt="{{ f.name }}"
                             class="w-14 h-14 shrink-0 border-2 border-base-300 bg-base-200 object-cover">
                        <div class="min-w-0 grow">
                            <div class="text-lg font-medium leading-tight">{{ f.name }}</div>
                            <div class="text-[11px] uppercase tracking-[0.14em] ia-text-gray mt-1">{{ f.sector }}</div>
                        </div>
                    </div>
                {% endfor %}
            </div>
            {% endif %}

            <p class="mt-6 text-center text-[11px] ia-text-gray leading-snug">
                Keep this page open — voting starts automatically when the moderator opens it.
            </p>
        </div>
    </div>
</div>
{% endblock %}
