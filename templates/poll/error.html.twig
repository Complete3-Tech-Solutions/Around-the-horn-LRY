{% extends 'base.html.twig' %}

{% block title %}Voting Not Open — Around the Horn{% endblock %}

{% block body %}
{% include 'components/_brand_header.html.twig' with {'heading': 'Around the Horn', 'subtitle': 'Audience voting'} %}
<div class="min-h-screen bg-base-100 grid place-items-center px-4">
    <div class="card bg-base-100 border-2 border-base-300 max-w-md w-full">
        <div class="card-body items-center text-center">
            <img src="/img/logo.svg" alt="Innovate Alabama" class="h-16 w-16 mb-2">
            <h1 class="text-2xl font-display" style="font-weight:200;">Voting isn't open right now</h1>
            <p class="ia-text-gray">{{ message }}</p>
            <p class="text-sm mt-2">Keep this page handy — the next round's QR code will appear on the screen shortly.</p>
        </div>
    </div>
</div>
{% endblock %}
