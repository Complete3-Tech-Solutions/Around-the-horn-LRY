{% extends 'base.html.twig' %}

{% block title %}Vote Submitted — Around the Horn{% endblock %}

{% block body %}
{% include 'components/_brand_header.html.twig' with {'heading': 'Around the Horn', 'subtitle': 'Audience voting'} %}
<div class="min-h-screen bg-base-100 grid place-items-center px-4 relative overflow-hidden"
     {% if auto_refresh|default(false) %}
     hx-get="{{ path('app_vote_live') }}"
     hx-trigger="every 3s"
     hx-select="body"
     hx-swap="outerHTML"
     {% endif %}>
    <div class="fireworks-container absolute inset-0 pointer-events-none"></div>
    <div class="card bg-base-100 border-2 border-base-300 max-w-md w-full relative z-10">
        <div class="card-body items-center text-center">
            <div class="ia-text-cyan mb-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-20 h-20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <h1 class="text-3xl font-display" style="font-weight:200;">Thank you!</h1>
            <p class="ia-text-gray">Your vote for "{{ title }}" was recorded.</p>
            <p class="text-sm mt-2">Watch the screen for the live result. Keep this page open for the next round — no need to scan again.</p>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const c = document.querySelector('.fireworks-container');
    if (c && window.Fireworks) {
        new window.Fireworks(c, { autoresize: true, opacity: 0.5, particles: 50, intensity: 25, hue: { min: 200, max: 220 } }).start();
    }
});
</script>
{% endblock %}
