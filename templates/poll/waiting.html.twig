{% extends 'base.html.twig' %}

{% block title %}Stand By — Around the Horn{% endblock %}

{% block body %}
{% include 'components/_brand_header.html.twig' with {'heading': 'Around the Horn', 'subtitle': 'Audience voting'} %}
<div class="min-h-screen bg-base-100 grid place-items-center px-4"
     hx-get="{{ path('app_vote_live') }}"
     hx-trigger="every 3s"
     hx-select="body"
     hx-swap="outerHTML">
    <div class="card bg-base-100 border-2 border-base-300 max-w-md w-full">
        <div class="card-body items-center text-center">
            <img src="/img/logo.svg" alt="Innovate Alabama" class="h-16 w-16 mb-2">
            <h1 class="text-2xl font-display" style="font-weight:200;">Stand by</h1>
            <p class="ia-text-gray">Voting for the next round opens soon.</p>
            <p class="text-sm mt-2">Keep this page open — no need to scan again.</p>
            <span class="loading loading-dots loading-md ia-text-cyan mt-4"></span>
        </div>
    </div>
</div>
{% endblock %}
