{% extends 'base.html.twig' %}

{% block title %}Stand By — Around the Horn{% endblock %}

{% block body %}
{% set founders = event_config.founders %}
{% set decided = decided_rounds|default([]) %}
{% set round_metas = round_metas|default([]) %}
{% set last_round = last_round|default(null) %}
{% set last_winners = last_winners|default([]) %}
{% set pending = round_metas|filter(r => r.number not in decided) %}
{% set next = pending|length > 0 ? pending|first : null %}

{# Self-polling shell — see poll/show.html.twig for why we swap #vote-app,
   never "body". #}
<div id="vote-app" class="ia-stage"
     hx-get="{{ path('app_vote_live') }}"
     hx-trigger="every 3s"
     hx-select="#vote-app"
     hx-swap="outerHTML">

    {% include 'components/_brand_header.html.twig' with {
        'compact': true,
        'stage': true,
        'subtitle': 'Audience voting',
        'badge': next ? next.key : null,
    } %}

    <div class="min-h-screen bg-base-100 px-3 py-9 grid place-items-center">
        <div class="max-w-md w-full mx-auto flex flex-col gap-6">

            <div class="border-2 border-base-300 text-center px-4 py-6">
                <img src="{{ event_state.theme == 'innovate-dark' ? '/img/logo.svg' : '/img/logo-ink.svg' }}" alt="Innovate Alabama" class="h-12 w-12 mx-auto mb-3">
                <h1 class="text-2xl font-display" style="font-weight:200;">
                    {% if last_round and last_winners is not empty %}
                        {{ last_round.key }} goes to {{ last_winners|map(f => f.name)|join(' & ') }}
                    {% elseif decided is empty %}
                        You're in — stand by
                    {% else %}
                        Round {{ decided|last }} is in the books
                    {% endif %}
                </h1>
                <p class="ia-text-gray text-sm mt-1">
                    {{ next
                        ? 'Voting opens here the moment the next round goes live.'
                        : (decided is not empty ? 'All rounds are in — champion reveal coming up.' : 'Voting opens here the moment the next round goes live.') }}
                </p>
                {% if next %}
                    <p class="mt-3 text-sm">
                        <span class="block text-[10px] uppercase tracking-[0.14em] ia-text-gray">{{ decided is empty ? 'First up' : 'Up next' }}</span>
                        <b>{{ next.key }}</b>
                    </p>
                {% endif %}
                <p class="text-[11px] ia-text-gray mt-3 flex items-center justify-center gap-2">
                    <span class="loading loading-dots loading-xs ia-text-cyan"></span>
                    Keep this page open — no need to scan again.
                </p>
            </div>

            {% if decided is empty %}
                <div class="border-2 border-base-300">
                    <div class="border-b-2 border-base-300 px-4 py-3">
                        <span class="font-display text-lg" style="font-weight:200;">Tonight's participants</span>
                    </div>
                    {% for f in founders %}
                        <div class="flex items-center gap-3 px-4 py-3 {{ not loop.last ? 'border-b border-base-300' : '' }}">
                            <img src="{{ f.headshot }}" alt="{{ f.name }}" class="w-10 h-10 shrink-0 border-2 border-base-300 bg-base-200 object-cover">
                            <div class="leading-tight">
                                <div class="font-medium">{{ f.name }}</div>
                                <div class="text-[10px] uppercase tracking-[0.14em] ia-text-gray">{{ f.sector }}</div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
                <p class="text-center text-xs ia-text-gray leading-relaxed px-3">{{ event_config.tagline }}</p>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
